{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ServerMonitor": {
    "Server": {
      "Port": 5000
    },
    "Ipmi": {
      "UseLocal": true,
      "Host": "127.0.0.1",
      "Username": "",
      "Password": "",
      "Interface": "lanplus",
      "CipherSuite": 3
    },
    "FanControl": {
      "EnableControl": false,
      "ManualSpeed": 20,
      "CheckIntervalSeconds": 30
    },
    "Stats": {
      "Network": {
        "//comment": "Optional whitelist (Include) - if set, ONLY these interfaces are reported.",
        "//comment2": "Exclude defaults to common virtual interfaces. Glob '*' is supported.",
        "Include": [],
        "Exclude": [ "lo", "veth*", "br-*", "docker*", "virbr*", "vnet*", "tun*", "tap*", "wg*" ]
      }
    },
    "ForceProvider": ""
  }
}
