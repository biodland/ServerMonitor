@{
    ViewData["Title"] = "Fan Control Status";
}

@model dynamic

<div class="container">
    <div class="header">
        <h1>🖥️ Dell R720 XD Fan Control</h1>
        <div class="subtitle">Real-time Temperature & Fan Speed Monitoring</div>
        <div class="status-info">
            <span id="lastUpdate">Last update: Loading...</span>
            <span class="refresh-indicator">🔄</span>
        </div>
    </div>

    <div id="errorMessage" class="error-message"></div>

    <div class="cards-grid">
        <!-- Temperature Card -->
        <div class="card">
            <div class="card-header">
                <span class="icon">🌡️</span>
                <h2>Temperature</h2>
            </div>
            <div class="main-value">
                <span class="temperature" id="highestTemp">--</span>
                <span class="unit">°C</span>
            </div>
            <div class="mode-badge" id="tempStatus">Loading...</div>
            <div style="margin-top: 15px; color: #888; font-size: 0.85rem;">
                All Sensors: <span id="allTempsCount">0</span> detected
            </div>
        </div>

        <!-- Fan Speed Card -->
        <div class="card">
            <div class="card-header">
                <span class="icon">💨</span>
                <h2>Fan Speed</h2>
            </div>
            <div class="main-value">
                <span class="rpm" id="avgFanRPM">--</span>
                <span class="unit">RPM (avg)</span>
            </div>
            <div class="mode-badge" id="fanModeBadge">Loading...</div>
            <div style="margin-top: 15px; color: #888; font-size: 0.85rem;">
                <span id="fanCount">0</span> fans active
            </div>
        </div>

        <!-- Control Mode Card -->
        <div class="card">
            <div class="card-header">
                <span class="icon">⚙️</span>
                <h2>Control Mode</h2>
            </div>
            <div style="text-align: center; margin: 30px 0;">
                <span class="mode-badge mode-manual" id="controlModeBadge" style="font-size: 1.1rem; padding: 12px 24px;">
                    Loading...
                </span>
            </div>
            <div style="color: #888; font-size: 0.85rem; text-align: center;">
                Current fan control strategy
            </div>
        </div>
    </div>

    <!-- Fan Details Card -->
    <div class="card">
        <div class="card-header">
            <span class="icon">📊</span>
            <h2>Fan Details</h2>
        </div>
        <div class="fan-list" id="fanList">
            <div style="text-align: center; color: #666; padding: 20px;">Loading fan information...</div>
        </div>
    </div>

    <!-- Control Panel -->
    <div class="control-panel">
        <h3>🎮 Manual Controls</h3>
        
        <div class="control-buttons">
            <button class="btn btn-success" onclick="restoreDynamicControl()">
                🔄 Restore Dynamic Control
            </button>
            <button class="btn btn-primary" onclick="toggleAutoControl()">
                ⚡ Toggle Automatic Control
            </button>
        </div>

        <div class="speed-controls">
            <div style="width: 100%; color: #888; font-size: 0.85rem; margin-bottom: 10px;">
                Quick Speed Presets:
            </div>
            <button class="speed-btn" onclick="setFanSpeed(10)">10% (Quiet)</button>
            <button class="speed-btn" onclick="setFanSpeed(15)">15% (Low)</button>
            <button class="speed-btn" onclick="setFanSpeed(20)">20% (Medium)</button>
            <button class="speed-btn" onclick="setFanSpeed(25)">25% (High)</button>
            <button class="speed-btn" onclick="setFanSpeed(35)">35% (Very High)</button>
            <button class="speed-btn" onclick="setFanSpeed(50)">50% (Max)</button>
        </div>
    </div>

    <div class="last-updated">
        <p>Dashboard auto-refreshes every 5 seconds</p>
        <p style="margin-top: 5px; color: #555;">Dell R720 XD Fan Control System v1.0</p>
    </div>
</div>

<script>
    let autoControlEnabled = true;

    // Initial load
    document.addEventListener('DOMContentLoaded', function() {
        updateStatus();
        startAutoRefresh();
    });

    async function updateStatus() {
        try {
            const response = await fetch('/api/status');
            const data = await response.json();

            // Update temperature
            const highestTemp = data.temperatures.highest;
            document.getElementById('highestTemp').textContent = highestTemp;
            
            // Update temperature status badge
            const tempStatus = document.getElementById('tempStatus');
            if (highestTemp < 40) {
                tempStatus.textContent = 'Normal';
                tempStatus.style.background = 'linear-gradient(90deg, #00ff88, #00d9ff)';
                tempStatus.style.color = '#1a1a2e';
            } else if (highestTemp < 50) {
                tempStatus.textContent = 'Elevated';
                tempStatus.style.background = 'linear-gradient(90deg, #ffa500, #ff6b6b)';
                tempStatus.style.color = 'white';
            } else {
                tempStatus.textContent = 'High';
                tempStatus.style.background = 'linear-gradient(90deg, #ff6b6b, #ee5a5a)';
                tempStatus.style.color = 'white';
            }

            // Update all temps count
            document.getElementById('allTempsCount').textContent = data.temperatures.all.length;

            // Update fan speed
            document.getElementById('avgFanRPM').textContent = data.fans.averageRPM;
            document.getElementById('fanCount').textContent = data.fans.count;

            // Update control mode
            const controlMode = data.mode;
            const modeBadge = document.getElementById('controlModeBadge');
            const fanModeBadge = document.getElementById('fanModeBadge');
            
            modeBadge.textContent = controlMode;
            fanModeBadge.textContent = controlMode;

            // Update badge styles
            modeBadge.className = 'mode-badge';
            fanModeBadge.className = 'mode-badge';

            if (controlMode.includes('Manual')) {
                modeBadge.classList.add('mode-manual');
                fanModeBadge.classList.add('mode-manual');
            } else if (controlMode.includes('Monitoring')) {
                modeBadge.classList.add('mode-monitoring');
                fanModeBadge.classList.add('mode-monitoring');
            } else {
                modeBadge.classList.add('mode-dynamic');
                fanModeBadge.classList.add('mode-dynamic');
            }

            // Update last update time
            const updateDate = new Date(data.timestamp);
            document.getElementById('lastUpdate').textContent = 'Last update: ' + updateDate.toLocaleTimeString();

            // Update fan list
            updateFanList(data.fans.fans, data.fans.averageRPM);

            // Hide error message
            document.getElementById('errorMessage').classList.remove('visible');
        } catch (error) {
            console.error('Failed to update status:', error);
            showError('Failed to connect to fan control service. Make sure the application is running.');
        }
    }

    function updateFanList(fans, averageRpm) {
        const fanList = document.getElementById('fanList');
        
        if (!fans || fans.length === 0) {
            fanList.innerHTML = '<div style="text-align: center; color: #666; padding: 20px;">No fan data available</div>';
            return;
        }

        fanList.innerHTML = fans.map(fan => {
            const percentage = (fan.rpm / averageRpm) * 100;
            const isHigh = percentage > 120;
            
            return `
                <div class="fan-item">
                    <div style="flex: 1;">
                        <div class="fan-name">${fan.name}</div>
                        <div class="progress-bar">
                            <div class="progress-fill ${isHigh ? 'high' : ''}" style="width: ${Math.min(percentage, 100)}%"></div>
                        </div>
                    </div>
                    <div style="text-align: right;">
                        <div class="fan-rpm">${fan.rpm} RPM</div>
                    </div>
                </div>
            `;
        }).join('');
    }

    async function setFanSpeed(speed) {
        try {
            const response = await fetch('/api/control/manual', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ speed: speed })
            });

            const result = await response.json();

            if (result.success) {
                autoControlEnabled = false;
                showSuccess(`Fan speed set to ${speed}%`);
                updateStatus();
            } else {
                showError('Failed to set fan speed: ' + (result.error || 'Unknown error'));
            }
        } catch (error) {
            showError('Error setting fan speed: ' + error.message);
        }
    }

    async function restoreDynamicControl() {
        try {
            const response = await fetch('/api/control/dynamic', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            const result = await response.json();

            if (result.success) {
                showSuccess('Dynamic control restored');
                autoControlEnabled = true;
                updateStatus();
            } else {
                showError('Failed to restore dynamic control: ' + (result.error || 'Unknown error'));
            }
        } catch (error) {
            showError('Error restoring dynamic control: ' + error.message);
        }
    }

    function toggleAutoControl() {
        autoControlEnabled = !autoControlEnabled;
        if (autoControlEnabled) {
            restoreDynamicControl();
        } else {
            showSuccess('Automatic control paused. Use speed presets to manually control fans.');
        }
    }

    function showError(message) {
        const errorDiv = document.getElementById('errorMessage');
        errorDiv.textContent = '❌ ' + message;
        errorDiv.classList.add('visible');
        setTimeout(() => errorDiv.classList.remove('visible'), 5000);
    }

    function showSuccess(message) {
        const errorDiv = document.getElementById('errorMessage');
        errorDiv.textContent = '✅ ' + message;
        errorDiv.classList.add('visible');
        errorDiv.style.background = 'rgba(0, 255, 136, 0.2)';
        errorDiv.style.borderColor = '#00ff88';
        errorDiv.style.color = '#00ff88';
        setTimeout(() => {
            errorDiv.classList.remove('visible');
            errorDiv.style.background = '';
            errorDiv.style.borderColor = '';
            errorDiv.style.color = '';
        }, 3000);
    }
</script>