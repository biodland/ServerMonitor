@{
    ViewData["Title"] = "Fan Control Status";
    Layout = "_Layout";
}

@model dynamic

<div class="dashboard">
    <!-- Compact Header -->
    <div class="header">
        <div class="header-left">
            <h1>🖥️ Dell R720 XD</h1>
            <span class="status-badge" id="systemStatus">● Online</span>
        </div>
        <div class="update-info">
            <span id="lastUpdate">Loading...</span>
            <span class="refresh-interval">• 5s refresh</span>
        </div>
    </div>

    <!-- Quick Stats Bar - Super Compact -->
    <div class="quick-stats">
        <div class="quick-stat temp-stat">
            <div class="quick-label">Max Temp</div>
            <div class="quick-value" id="maxTemp">--°C</div>
            <div class="quick-indicator" id="tempIndicator"></div>
        </div>
        <div class="quick-stat fan-stat">
            <div class="quick-label">Fans</div>
            <div class="quick-value" id="avgRpm">-- RPM</div>
            <div class="quick-sub" id="fanCount">0 fans</div>
        </div>
        <div class="quick-stat power-stat">
            <div class="quick-label">Power</div>
            <div class="quick-value" id="totalPower">-- W</div>
            <div class="quick-sub" id="powerSource">Loading</div>
        </div>
        <div class="quick-stat mode-stat">
            <div class="quick-label">Mode</div>
            <div class="quick-value" id="controlMode">--</div>
            <div class="quick-sub" id="controlModeDetail">Manual</div>
        </div>
    </div>

    <!-- Message -->
    <div id="message" class="message"></div>

    <!-- Main Content Grid -->
    <div class="content-grid">
        <!-- CPU Section -->
        <div class="section-card">
            <div class="section-title">
                <span class="section-icon">🖥️</span>
                <span class="section-name">CPU Temperatures</span>
                <span class="item-count" id="cpuCoreCount">0</span>
            </div>
            <div class="section-content">
                <div class="cores-container" id="cpuCoresGrid">
                    <div class="loading">Loading...</div>
                </div>
            </div>
        </div>

        <!-- Sensors Section -->
        <div class="section-card">
            <div class="section-title">
                <span class="section-icon">🌡️</span>
                <span class="section-name">Temperature Sensors</span>
                <span class="item-count" id="sensorCount">0</span>
            </div>
            <div class="section-content">
                <div class="sensors-container" id="sensorsGrid">
                    <div class="loading">Loading...</div>
                </div>
            </div>
        </div>

        <!-- GPUs Section -->
        <div class="section-card gpu-section" id="gpuSection" style="display: none;">
            <div class="section-title">
                <span class="section-icon">🎮</span>
                <span class="section-name">GPU Temperatures</span>
                <span class="item-count" id="gpuCount">0</span>
            </div>
            <div class="section-content">
                <div class="gpus-container" id="gpusGrid"></div>
            </div>
        </div>
    </div>

    <!-- Compact Charts -->
    <div class="charts-container" id="chartsContainer">
        <div class="chart-card">
            <div class="chart-title">📊 Temperature</div>
            <canvas id="tempChart" height="100"></canvas>
        </div>
        <div class="chart-card">
            <div class="chart-title">📊 Fans</div>
            <canvas id="fanChart" height="100"></canvas>
        </div>
        <div class="chart-card">
            <div class="chart-title">📊 Power</div>
            <canvas id="powerChart" height="100"></canvas>
        </div>
    </div>

    <!-- Fans List -->
    <div class="section-card">
        <div class="section-title">
            <span class="section-icon">💨</span>
            <span class="section-name">Fan Speeds</span>
            <span class="item-count" id="fanListCount">0</span>
        </div>
        <div class="section-content">
            <div class="fans-grid" id="fansGrid">
                <div class="loading">Loading...</div>
            </div>
        </div>
    </div>

    <!-- Controls -->
    <div class="controls-card">
        <div class="section-title">
            <span class="section-icon">🎛️</span>
            <span class="section-name">Fan Control</span>
        </div>
        <div class="controls-content">
            <button class="btn btn-primary" onclick="restoreDynamic()">🔄 Auto (Dynamic)</button>
            <div class="speed-buttons">
                <button class="speed-btn" data-speed="10">10%</button>
                <button class="speed-btn" data-speed="15">15%</button>
                <button class="speed-btn" data-speed="20">20%</button>
                <button class="speed-btn" data-speed="25">25%</button>
                <button class="speed-btn" data-speed="35">35%</button>
                <button class="speed-btn" data-speed="50">50%</button>
            </div>
        </div>
    </div>
</div>

<script>
    // Chart.js with multiple CDN fallbacks
    function loadChartJS() {
        const cdns = [
            'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js',
            'https://unpkg.com/chart.js@4.4.0/dist/chart.umd.min.js',
            'https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js'
        ];

        let attempt = 0;
        function loadScript() {
            const script = document.createElement('script');
            script.src = cdns[attempt];
            script.crossOrigin = 'anonymous';
            script.onerror = () => {
                console.warn(`CDN ${cdns[attempt]} failed, trying next...`);
                attempt++;
                if (attempt < cdns.length) {
                    loadScript();
                } else {
                    console.error('All Chart.js CDNs failed');
                    document.getElementById('chartsContainer').style.display = 'none';
                    initDashboard();
                }
            };
            script.onload = () => {
                console.log('Chart.js loaded from', cdns[attempt]);
                initDashboard();
            };
            document.head.appendChild(script);
        }
        loadScript();
    }

    // Global chart instances
    let tempChart, fanChart, powerChart;
    let refreshInterval;
    let maxDataPoints = 60;
    window.Chart = null;

    function initDashboard() {
        if (typeof Chart !== 'undefined') {
            initCharts();
        }
        updateDashboard();
        startAutoRefresh();
    }

    function initCharts() {
        const chartOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                x: {
                    display: false
                },
                y: {
                    display: true,
                    grid: { color: 'rgba(255,255,255,0.05)' },
                    ticks: { color: '#666', font: { size: 10 } }
                }
            },
            elements: {
                point: { radius: 0 },
                line: { tension: 0.4 }
            },
            animation: { duration: 300 }
        };

        tempChart = new Chart(document.getElementById('tempChart'), {
            type: 'line',
            data: { labels: [], datasets: [{ data: [], borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.1)', fill: true }] },
            options: { ...chartOptions, scales: { ...chartOptions.scales, y: { ...chartOptions.scales.y, min: 20, max: 80 } } }
        });

        fanChart = new Chart(document.getElementById('fanChart'), {
            type: 'line',
            data: { labels: [], datasets: [{ data: [], borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.1)', fill: true }] },
            options: { ...chartOptions, scales: { ...chartOptions.scales, y: { ...chartOptions.scales.y, min: 0, max: 20000 } } }
        });

        powerChart = new Chart(document.getElementById('powerChart'), {
            type: 'line',
            data: { labels: [], datasets: [{ data: [], borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.1)', fill: true }] },
            options: { ...chartOptions, scales: { ...chartOptions.scales, y: { ...chartOptions.scales.y, min: 0, max: 500 } } }
        });
    }

    function startAutoRefresh() {
        if (refreshInterval) clearInterval(refreshInterval);
        refreshInterval = setInterval(updateDashboard, 5000);
    }

    async function updateDashboard() {
        try {
            const response = await fetch('/api/status');
            const data = await response.json();

            // Update time
            const time = new Date(data.timestamp);
            document.getElementById('lastUpdate').textContent = time.toLocaleTimeString();

            // Quick stats
            document.getElementById('maxTemp').textContent = data.temperatureStatus.highest + '°C';
            document.getElementById('avgRpm').textContent = data.fans.averageRPM + ' RPM';
            document.getElementById('fanCount').textContent = data.fans.count + ' fans';
            document.getElementById('totalPower').textContent = data.power.totalWatts.toFixed(1) + ' W';
            document.getElementById('powerSource').textContent = data.power.source || 'Est';
            document.getElementById('controlMode').textContent = data.mode;
            document.getElementById('controlModeDetail').textContent = data.mode.includes('Manual') ? 'Manual' : 'Auto';

            // Temperature indicator
            const tempIndicator = document.getElementById('tempIndicator');
            const maxTemp = data.temperatureStatus.highest;
            if (maxTemp < 40) {
                tempIndicator.className = 'quick-indicator good';
            } else if (maxTemp < 50) {
                tempIndicator.className = 'quick-indicator warning';
            } else {
                tempIndicator.className = 'quick-indicator bad';
            }

            // Update sections
            updateCpuCores(data.system.cpuCores);
            updateSensors(data.sensors.temperatures);
            updateGpus(data.system.gpus);
            updateFans(data.fans);

            // Update charts
            if (typeof Chart !== 'undefined') {
                updateCharts(data);
            }

        } catch (error) {
            console.error('Update failed:', error);
            showMessage('❌ Connection failed', 'error');
        }
    }

    function updateCpuCores(cores) {
        const grid = document.getElementById('cpuCoresGrid');
        document.getElementById('cpuCoreCount').textContent = cores.length;

        if (cores.length === 0) {
            grid.innerHTML = '<div class="no-data">No data</div>';
            return;
        }

        grid.innerHTML = cores.map(core => {
            const status = core.temperature < 45 ? 'good' : core.temperature < 55 ? 'warning' : 'bad';
            const width = Math.min((core.temperature / 90) * 100, 100);
            return `
                <div class="core-item ${core.isPackage ? 'package' : ''}">
                    <div class="core-name">${core.name}</div>
                    <div class="core-bar-bg"><div class="core-bar ${status}" style="width: ${width}%"></div></div>
                    <div class="core-temp ${status}">${core.temperature}°C</div>
                </div>
            `;
        }).join('');
    }

    function updateSensors(sensors) {
        const grid = document.getElementById('sensorsGrid');
        document.getElementById('sensorCount').textContent = sensors.length;

        if (sensors.length === 0) {
            grid.innerHTML = '<div class="no-data">No data</div>';
            return;
        }

        grid.innerHTML = sensors.map(s => {
            const status = s.temperature < 40 ? 'good' : s.temperature < 50 ? 'warning' : 'bad';
            const width = Math.min((s.temperature / 90) * 100, 100);
            return `
                <div class="sensor-item">
                    <div class="sensor-name">${s.name}</div>
                    <div class="sensor-bar-bg"><div class="sensor-bar ${status}" style="width: ${width}%"></div></div>
                    <div class="sensor-temp ${status}">${s.temperature}°C</div>
                </div>
            `;
        }).join('');
    }

    function updateGpus(gpus) {
        const section = document.getElementById('gpuSection');
        const grid = document.getElementById('gpusGrid');
        document.getElementById('gpuCount').textContent = gpus.length;

        if (gpus.length === 0) {
            section.style.display = 'none';
            return;
        }

        section.style.display = 'block';
        grid.innerHTML = gpus.map(gpu => {
            const status = gpu.temperature < 60 ? 'good' : gpu.temperature < 75 ? 'warning' : 'bad';
            const width = Math.min((gpu.temperature / 100) * 100, 100);
            return `
                <div class="gpu-item">
                    <div class="gpu-name">${gpu.name}</div>
                    <div class="gpu-bar-bg"><div class="gpu-bar ${status}" style="width: ${width}%"></div></div>
                    <div class="gpu-temp ${status}">${gpu.temperature}°C</div>
                    ${gpu.fanSpeed ? `<div class="gpu-fan">💨 ${gpu.fanSpeed}%</div>` : ''}
                </div>
            `;
        }).join('');
    }

    function updateFans(fansData) {
        const grid = document.getElementById('fansGrid');
        document.getElementById('fanListCount').textContent = fansData.count;

        if (fansData.fans.length === 0) {
            grid.innerHTML = '<div class="no-data">No data</div>';
            return;
        }

        grid.innerHTML = fansData.fans.map(fan => {
            const width = Math.min((fan.rpm / 20000) * 100, 100);
            return `
                <div class="fan-item">
                    <div class="fan-name">${fan.name}</div>
                    <div class="fan-bar-bg"><div class="fan-bar" style="width: ${width}%"></div></div>
                    <div class="fan-rpm">${fan.rpm}</div>
                </div>
            `;
        }).join('');
    }

    function updateCharts(data) {
        const time = new Date().getTime();

        [tempChart, fanChart, powerChart].forEach((chart, index) => {
            const datasets = [
                [data.temperatureStatus.highest],
                [data.fans.averageRPM],
                [data.power.totalWatts]
            ][index];

            chart.data.labels.push(time);
            chart.data.datasets[0].data.push(datasets[0]);

            if (chart.data.labels.length > maxDataPoints) {
                chart.data.labels.shift();
                chart.data.datasets[0].data.shift();
            }
            chart.update('none');
        });
    }

    async function setSpeed(speed) {
        try {
            const response = await fetch('/api/control/manual', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ speed: speed })
            });
            const result = await response.json();
            showMessage(result.success ? `✓ Fan at ${speed}%` : '✖ Failed', result.success ? 'success' : 'error');
            if (result.success) updateDashboard();
        } catch {
            showMessage('✖ Failed', 'error');
        }
    }

    async function restoreDynamic() {
        try {
            const response = await fetch('/api/control/dynamic', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
            const result = await response.json();
            showMessage(result.success ? '✓ Auto mode' : '✖ Failed', result.success ? 'success' : 'error');
            if (result.success) updateDashboard();
        } catch {
            showMessage('✖ Failed', 'error');
        }
    }

    function showMessage(text, type) {
        const msg = document.getElementById('message');
        msg.textContent = text;
        msg.className = 'message ' + type;
        setTimeout(() => msg.className = 'message', 3000);
    }

    // Speed button handlers
    document.addEventListener('click', (e) => {
        if (e.target.classList.contains('speed-btn')) {
            setSpeed(parseInt(e.target.dataset.speed));
        }
    });

    // Start loading
    loadChartJS();
</script>