@{
    ViewData["Title"] = "Fan Control Status";
}

@model dynamic

<div class="dashboard">
    <!-- Header -->
    <div class="header">
        <div class="header-content">
            <div class="title-row">
                <h1>🖥️ Dell R720 XD</h1>
                <span class="status-badge" id="systemStatus">● Online</span>
            </div>
            <div class="subtitle">Fan Control & Temperature Monitoring</div>
        </div>
        <div class="last-update" id="lastUpdate">Loading...</div>
    </div>

    <!-- Error/Success Message -->
    <div id="message" class="message"></div>

    <!-- Main Stats Grid -->
    <div class="stats-grid">
        <!-- Temperature Card -->
        <div class="tile-card tile-temperature">
            <div class="tile-icon">🌡️</div>
            <div class="tile-content">
                <div class="tile-title">Max Temperature</div>
                <div class="tile-value"><span id="maxTemp">--</span><span class="unit">°C</span></div>
                <div class="tile-status" id="tempStatus">Loading...</div>
            </div>
        </div>

        <!-- Fans Card -->
        <div class="tile-card tile-fans">
            <div class="tile-icon">💨</div>
            <div class="tile-content">
                <div class="tile-title">Avg Fan Speed</div>
                <div class="tile-value"><span id="avgRpm">--</span><span class="unit">RPM</span></div>
                <div class="tile-status"><span id="fanCount">0</span> fans</div>
            </div>
        </div>

        <!-- Power Card -->
        <div class="tile-card tile-power">
            <div class="tile-icon">⚡</div>
            <div class="tile-content">
                <div class="tile-title">Power Draw</div>
                <div class="tile-value"><span id="totalPower">--</span><span class="unit">W</span></div>
                <div class="tile-status" id="powerSource">Loading...</div>
            </div>
        </div>

        <!-- Control Mode Card -->
        <div class="tile-card tile-mode">
            <div class="tile-icon">⚙️</div>
            <div class="tile-content">
                <div class="tile-title">Control Mode</div>
                <div class="tile-value-small" id="controlMode">Loading...</div>
                <div class="tile-status" id="controlModeDetail">Manual</div>
            </div>
        </div>
    </div>

    <!-- Main Grid Layout -->
    <div class="main-grid">
        <!-- Left Column: CPU Cores -->
        <div class="grid-section">
            <div class="section-header">
                <h2>🖥️ CPU Core Temperatures</h2>
                <span class="item-count" id="cpuCoreCount">0 cores</span>
            </div>
            <div class="cpu-cores-grid" id="cpuCoresGrid">
                <div class="loading">Loading CPU cores...</div>
            </div>
        </div>

        <!-- Middle Column: IPMI Sensors -->
        <div class="grid-section">
            <div class="section-header">
                <h2>🌡️ Temperature Sensors</h2>
                <span class="item-count" id="sensorCount">0 sensors</span>
            </div>
            <div class="sensors-grid" id="sensorsGrid">
                <div class="loading">Loading sensors...</div>
            </div>
        </div>

        <!-- Right Column: GPUs and Fans -->
        <div class="grid-section">
            <div class="section-header">
                <h2>🎮 GPU Temperatures</h2>
                <span class="item-count" id="gpuCount">0 GPUs</span>
            </div>
            <div class="gpus-grid" id="gpusGrid">
                <div class="no-data">No GPUs detected</div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="charts-section">
        <div class="chart-container">
            <h3>📊 Temperature History</h3>
            <canvas id="tempChart"></canvas>
        </div>
        <div class="chart-container">
            <h3>📊 Fan Speed History</h3>
            <canvas id="fanChart"></canvas>
        </div>
        <div class="chart-container">
            <h3>📊 Power Consumption</h3>
            <canvas id="powerChart"></canvas>
        </div>
    </div>

    <!-- Fan Details Section -->
    <div class="fans-section">
        <div class="section-header">
            <h2>💨 Fan Status</h2>
            <span class="item-count" id="fanCountDetail">0 fans</span>
        </div>
        <div class="fans-grid" id="fansGrid">
            <div class="loading">Loading fans...</div>
        </div>
    </div>

    <!-- Controls Section -->
    <div class="controls-section">
        <div class="section-header">
            <h2>🎛️ Speed Controls</h2>
        </div>
        <div class="controls-content">
            <button class="btn btn-restore" onclick="restoreDynamic()">🔄 Restore Auto</button>
            <div class="speed-presets">
                <button class="speed-btn" onclick="setSpeed(10)">10%</button>
                <button class="speed-btn" onclick="setSpeed(15)">15%</button>
                <button class="speed-btn" onclick="setSpeed(20)">20%</button>
                <button class="speed-btn" onclick="setSpeed(25)">25%</button>
                <button class="speed-btn" onclick="setSpeed(35)">35%</button>
                <button class="speed-btn" onclick="setSpeed(50)">50%</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    // Global variables for charts
    let tempChart, fanChart, powerChart;
    let refreshInterval = null;
    let maxDataPoints = 60; // Show last 5 minutes of data

    document.addEventListener('DOMContentLoaded', () => {
        initCharts();
        updateDashboard();
        startAutoRefresh();
    });

    function initCharts() {
        const commonOptions = {
            responsive: true,
            maintainAspectRatio: true,
            animation: { duration: 300 },
            scales: {
                x: {
                    display: true,
                    grid: { color: 'rgba(255,255,255,0.1)' },
                    ticks: { color: '#888', maxTicksLimit: 10 }
                },
                y: {
                    display: true,
                    grid: { color: 'rgba(255,255,255,0.1)' },
                    ticks: { color: '#888' }
                }
            },
            plugins: {
                legend: {
                    labels: { color: '#fff', font: { size: 11 } }
                }
            }
        };

        // Temperature Chart
        tempChart = new Chart(document.getElementById('tempChart'), {
            type: 'line',
            data: {
                labels: [],
                datasets: [{
                    label: 'Max Temp (°C)',
                    data: [],
                    borderColor: '#ff6b6b',
                    backgroundColor: 'rgba(255,107,107,0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: commonOptions
        });

        // Fan Chart
        fanChart = new Chart(document.getElementById('fanChart'), {
            type: 'line',
            data: {
                labels: [],
                datasets: [{
                    label: 'Avg RPM',
                    data: [],
                    borderColor: '#00d9ff',
                    backgroundColor: 'rgba(0,217,255,0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: commonOptions
        });

        // Power Chart
        powerChart = new Chart(document.getElementById('powerChart'), {
            type: 'line',
            data: {
                labels: [],
                datasets: [{
                    label: 'Power (W)',
                    data: [],
                    borderColor: '#ffd700',
                    backgroundColor: 'rgba(255,215,0,0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: commonOptions
        });
    }

    function startAutoRefresh() {
        if (refreshInterval) clearInterval(refreshInterval);
        refreshInterval = setInterval(updateDashboard, 5000);
    }

    async function updateDashboard() {
        try {
            const response = await fetch('/api/status');
            const data = await response.json();

            // Update header timestamp
            const time = new Date(data.timestamp);
            document.getElementById('lastUpdate').textContent = 
                'Updated: ' + time.toLocaleTimeString();

            // Update stats
            updateStats(data);
            
            // Update CPU cores
            updateCpuCores(data.system.cpuCores);
            
            // Update sensors
            updateSensors(data.sensors.temperatures);
            
            // Update GPUs
            updateGpus(data.system.gpus);
            
            // Update fans
            updateFans(data.fans);

            // Update charts
            updateCharts(data);

        } catch (error) {
            console.error('Update failed:', error);
            showMessage('❌ Connection failed', 'error');
        }
    }

    function updateStats(data) {
        const maxTemp = data.temperatureStatus.highest;
        document.getElementById('maxTemp').textContent = maxTemp;
        document.getElementById('avgRpm').textContent = data.fans.averageRPM;
        document.getElementById('fanCount').textContent = data.fans.count;
        document.getElementById('controlMode').textContent = data.mode;
        
        // Power
        const totalPower = data.power.totalWatts;
        document.getElementById('totalPower').textContent = totalPower.toFixed(1);
        document.getElementById('powerSource').textContent = data.power.source || 'Estimated';

        // Temperature status
        const tempStatus = document.getElementById('tempStatus');
        if (maxTemp < 40) {
            tempStatus.textContent = '✓ Normal';
            tempStatus.style.color = '#00ff88';
        } else if (maxTemp < 50) {
            tempStatus.textContent = '⚠ Elevated';
            tempStatus.style.color = '#ffa500';
        } else {
            tempStatus.textContent = '🔥 High';
            tempStatus.style.color = '#ff6b6b';
        }

        // Control mode styling
        const modeEl = document.getElementById('controlMode');
        if (data.mode.includes('Manual')) {
            modeEl.style.color = '#ff6b6b';
            document.getElementById('controlModeDetail').textContent = 'Manual Control';
        } else {
            modeEl.style.color = '#00d9ff';
            document.getElementById('controlModeDetail').textContent = 'Automatic';
        }
    }

    function updateCpuCores(cores) {
        const grid = document.getElementById('cpuCoresGrid');
        document.getElementById('cpuCoreCount').textContent = cores.length + ' cores';

        if (cores.length === 0) {
            grid.innerHTML = '<div class="no-data">No CPU cores detected</div>';
            return;
        }

        grid.innerHTML = cores.map(core => {
            const statusColor = core.temperature < 45 ? '#00ff88' : 
                               core.temperature < 55 ? '#ffa500' : '#ff6b6b';
            const tempPercent = Math.min((core.temperature / 100) * 100, 100);
            
            return `
                <div class="core-tile ${core.isPackage ? 'core-package' : ''}">
                    <div class="core-name">${core.name}</div>
                    <div class="core-visual">
                        <div class="core-bar" style="width: ${tempPercent}%; background: ${statusColor}"></div>
                    </div>
                    <div class="core-value" style="color: ${statusColor}">${core.temperature}°C</div>
                </div>
            `;
        }).join('');
    }

    function updateSensors(sensors) {
        const grid = document.getElementById('sensorsGrid');
        document.getElementById('sensorCount').textContent = sensors.length + ' sensors';

        if (sensors.length === 0) {
            grid.innerHTML = '<div class="no-data">No sensors detected</div>';
            return;
        }

        grid.innerHTML = sensors.map(s => {
            const statusColor = s.temperature < 40 ? '#00ff88' : 
                               s.temperature < 50 ? '#ffa500' : '#ff6b6b';
            const tempPercent = Math.min((s.temperature / 100) * 100, 100);
            
            return `
                <div class="sensor-tile">
                    <div class="sensor-name">${s.name}</div>
                    <div class="sensor-visual">
                        <div class="sensor-bar" style="width: ${tempPercent}%; background: ${statusColor}"></div>
                    </div>
                    <div class="sensor-value" style="color: ${statusColor}">${s.temperature}°C</div>
                </div>
            `;
        }).join('');
    }

    function updateGpus(gpus) {
        const grid = document.getElementById('gpusGrid');
        document.getElementById('gpuCount').textContent = gpus.length + ' GPUs';

        if (gpus.length === 0) {
            grid.innerHTML = '<div class="no-data">No GPUs detected</div>';
            return;
        }

        grid.innerHTML = gpus.map(gpu => {
            const typeIcon = gpu.type === 'NVIDIA' ? '🟢' : 
                           gpu.type === 'AMD' ? '🔴' : '🔵';
            const statusColor = gpu.temperature < 60 ? '#00ff88' : 
                               gpu.temperature < 75 ? '#ffa500' : '#ff6b6b';
            const tempPercent = Math.min((gpu.temperature / 100) * 100, 100);
            
            return `
                <div class="gpu-tile">
                    <div class="gpu-header">
                        <span class="gpu-name">${gpu.name}</span>
                        <span class="gpu-type">${typeIcon} ${gpu.type}</span>
                    </div>
                    <div class="gpu-visual">
                        <div class="gpu-bar" style="width: ${tempPercent}%; background: ${statusColor}"></div>
                    </div>
                    <div class="gpu-value" style="color: ${statusColor}">${gpu.temperature}°C</div>
                    ${gpu.fanSpeed ? `<div class="gpu-fan">💨 ${gpu.fanSpeed}%</div>` : ''}
                </div>
            `;
        }).join('');
    }

    function updateFans(fansData) {
        const grid = document.getElementById('fansGrid');
        document.getElementById('fanCountDetail').textContent = fansData.count + ' fans';

        if (fansData.fans.length === 0) {
            grid.innerHTML = '<div class="no-data">No fan data</div>';
            return;
        }

        const avg = fansData.averageRPM;
        grid.innerHTML = fansData.fans.map(fan => {
            const percent = Math.min((fan.rpm / 20000) * 100, 100);
            return `
                <div class="fan-tile">
                    <div class="fan-name">${fan.name}</div>
                    <div class="fan-visual">
                        <div class="fan-bar" style="width: ${percent}%"></div>
                    </div>
                    <div class="fan-value">${fan.rpm} RPM</div>
                </div>
            `;
        }).join('');
    }

    function updateCharts(data) {
        const time = new Date().toLocaleTimeString('en-US', { hour12: false });

        // Temperature chart
        tempChart.data.labels.push(time);
        tempChart.data.datasets[0].data.push(data.temperatureStatus.highest);
        if (tempChart.data.labels.length > maxDataPoints) {
            tempChart.data.labels.shift();
            tempChart.data.datasets[0].data.shift();
        }
        tempChart.update('none');

        // Fan chart
        fanChart.data.labels.push(time);
        fanChart.data.datasets[0].data.push(data.fans.averageRPM);
        if (fanChart.data.labels.length > maxDataPoints) {
            fanChart.data.labels.shift();
            fanChart.data.datasets[0].data.shift();
        }
        fanChart.update('none');

        // Power chart
        powerChart.data.labels.push(time);
        powerChart.data.datasets[0].data.push(data.power.totalWatts);
        if (powerChart.data.labels.length > maxDataPoints) {
            powerChart.data.labels.shift();
            powerChart.data.datasets[0].data.shift();
        }
        powerChart.update('none');
    }

    async function setSpeed(speed) {
        try {
            const response = await fetch('/api/control/manual', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ speed: speed })
            });
            const result = await response.json();
            
            if (result.success) {
                showMessage(`✓ Fan speed set to ${speed}%`, 'success');
                updateDashboard();
            } else {
                showMessage('✖ ' + result.error, 'error');
            }
        } catch (error) {
            showMessage('✖ Failed to set speed', 'error');
        }
    }

    async function restoreDynamic() {
        try {
            const response = await fetch('/api/control/dynamic', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const result = await response.json();
            
            if (result.success) {
                showMessage('✓ Dynamic control restored', 'success');
                updateDashboard();
            } else {
                showMessage('✖ ' + result.error, 'error');
            }
        } catch (error) {
            showMessage('✖ Failed to restore control', 'error');
        }
    }

    function showMessage(text, type) {
        const msg = document.getElementById('message');
        msg.textContent = text;
        msg.className = 'message ' + type;
        
        clearTimeout(window.messageTimeout);
        window.messageTimeout = setTimeout(() => {
            msg.className = 'message';
        }, 3000);
    }
</script>